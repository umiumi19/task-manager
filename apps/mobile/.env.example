# Supabase（モバイルから認証・API 用）
# backend とは別に apps/mobile/.env を用意する
#
# ローカル（supabase start）の場合:
#   cd apps/backend && pnpm supabase:status で API URL と anon key を確認し、その値を入れる
#   例: SUPABASE_URL=http://127.0.0.1:54321
#       SUPABASE_ANON_KEY=eyJ...（表示された長い文字列）
#
# クラウドの場合:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
